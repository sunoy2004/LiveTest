# Host / uvicorn on your machine (NOT inside Docker):
DATABASE_URL=postgresql://postgres:123456@/users_db?host=/cloudsql/yanc-website%3Aus-central1%3Amentor-mentee-db
# DATABASE_URL=postgresql+asyncpg://postgres:123456@/recommendation_db?host=/cloudsql/yanc-website:us-central1:mentor-mentee-db
# Full Docker stack from repo root: postgres host is `postgres`, DB `users_db` (see ../docker-compose.yml).
REDIS_URL=redis://localhost:6379/0

# Inside Docker Compose, do NOT put localhost DATABASE_URL in a file that the container loads.
# user-service/docker-compose.yml sets DATABASE_URL to the Postgres service name "user-db".
JWT_SECRET=
# Host dev: short lifetime is fine. Root docker-compose.yml defaults to 2880 (48h) for user-service.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: Gamification Service for booking saga (same Docker network: http://gamification-service:8000)
GAMIFICATION_SERVICE_URL=http://localhost:8002

# --- Google Meet (optional): real meet.google.com links on booking via Calendar API ---
# Set GMEET_ENABLED=true and use ONE auth method:
#
# (A) OAuth (personal / any Gmail): create OAuth client in Google Cloud, run one-time OAuth
#     flow to get a refresh token with scope calendar.events, then set:
# GMEET_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
#
# (B) Google Workspace: service account with domain-wide delegation for Calendar scope,
#     plus the user calendar to act as (must be in your Workspace):
# GMEET_ENABLED=false
# GMEET_DELEGATED_USER=mentor@yourdomain.com
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or paste JSON: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
#
# GMEET_CALENDAR_ID=primary

# Shared secret for GET /internal/matchmaking/snapshot (AI service hydrates graph from this)
INTERNAL_API_TOKEN=change-me-in-production

# Dev: on each startup, reset admin@test.com password and ensure admin_profiles row exists.
# Set to false in production after changing the admin password.
USERSERVICE_RESET_ADMIN_PASSWORD=true
SKIP_SEED=true

MENTORING_DATABASE_URL=postgresql://postgres:123456@/mentoring?host=/cloudsql/yanc-website%3Aus-central1%3Amentor-mentee-db