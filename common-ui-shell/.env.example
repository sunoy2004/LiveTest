# User Service base URL (identity). Same as common-ui-shell for standalone + localStorage parity.
# Must be the FastAPI User Service (default port 8000), NOT the MFE or shell port (e.g. do not use 8080).
# Omit or leave empty to use same-origin `/user-service` (Vite proxies to 8000 — see vite.config.ts).
VITE_USER_SERVICE_URL=http://127.0.0.1:8000

# Same origin as User Service for consolidated /api/v1 (mentorship requests + admin).
VITE_MENTORING_API_BASE_URL=http://127.0.0.1:8000

# Standalone mentoring FastAPI (X-User-Id) when using repo-root docker-compose.yml only:
# http://localhost:8004 — leave VITE_MENTORING_API_BASE_URL on 8000 if you use user-service routes only.

# Gamification (credit ledger) — balance widget; same port as Docker `gamification-service` (8002).
# VITE_CREDIT_SERVICE_URL is still accepted as a fallback in `creditServiceApi.ts`.
VITE_GAMIFICATION_SERVICE_URL=http://localhost:8002

# AI Matching service (GET /recommendations?user_id=…)
VITE_AI_API_BASE_URL=http://localhost:8001

# Port for `vite preview` / federation remote (`remoteEntry.js`). Must match common-ui-shell `VITE_MFE_REMOTE_PORT`.
VITE_MFE_REMOTE_PORT=5001

# Remote is not supported in bundleless `vite dev` for this plugin. Use:
#   npm run build && npm run serve:federation
# or one-shot: npm run dev:federation
# For hot rebuilds: one terminal `npm run build:watch`, another `npm run serve:federation`.
