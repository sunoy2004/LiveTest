REDIS_URL=redis://localhost:6379/0
# Async SQLAlchemy URL (asyncpg) for application; Alembic uses psycopg2 (see README)
DATABASE_URL=postgresql+asyncpg://postgres:123456@/user_db?host=/cloudsql/yanc-website:us-central1:mentor-mentee-db
USER_SERVICE_URL=http://user-service:8000
INTERNAL_API_TOKEN=change-me-in-production
JWT_SECRET=secret
# Dev only: skip JWT verification on recommendations (not for production)
AI_TRUST_GATEWAY_HEADERS=false

# opensource (default) | vertex
EMBEDDING_PROVIDER=opensource
USE_VERTEX=false
# RECOMMENDATION_ENGINE=pgvector
# RECOMMENDATION_CACHE_TTL=300
# HYBRID_SCORING=false
