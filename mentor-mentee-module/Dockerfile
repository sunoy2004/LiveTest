# Build stage
FROM node:20-alpine AS build
WORKDIR /app
ARG VITE_USER_SERVICE_URL
ARG VITE_MENTORING_API_BASE_URL
ARG VITE_AI_API_BASE_URL
ARG VITE_GAMIFICATION_SERVICE_URL
ARG VITE_MFE_REMOTE_PORT

ENV VITE_USER_SERVICE_URL=$VITE_USER_SERVICE_URL
ENV VITE_MENTORING_API_BASE_URL=$VITE_MENTORING_API_BASE_URL
ENV VITE_AI_API_BASE_URL=$VITE_AI_API_BASE_URL
ENV VITE_GAMIFICATION_SERVICE_URL=$VITE_GAMIFICATION_SERVICE_URL
ENV VITE_MFE_REMOTE_PORT=$VITE_MFE_REMOTE_PORT

COPY package*.json ./
RUN npm install
COPY . .
RUN VITE_USER_SERVICE_URL=$VITE_USER_SERVICE_URL \
    VITE_MENTORING_API_BASE_URL=$VITE_MENTORING_API_BASE_URL \
    VITE_AI_API_BASE_URL=$VITE_AI_API_BASE_URL \
    VITE_GAMIFICATION_SERVICE_URL=$VITE_GAMIFICATION_SERVICE_URL \
    npm run build

# Production stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.mfe.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
