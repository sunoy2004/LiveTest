# Async PostgreSQL URL for SQLAlchemy + asyncpg.
# Shape: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local: from backend/, `docker compose up -d` (see README) creates DB "mentoring".
# Repo-root stack: Postgres exposes 5432; use the same URL with host localhost when not in-container.
# Inside root docker-compose.yml use: postgresql+asyncpg://postgres:postgres@postgres:5432/mentoring
DATABASE_URL=postgresql+asyncpg://postgres:123456@/mentoring?host=/cloudsql/yanc-website%3Aus-central1%3Amentor-mentee-db

JWT_SECRET=7c9e2b1f8a4d6c3e0b5a9f2d8e4c7a1b0d5f2e8c4a7b1d9f6e0c3b8a5d2f4e7b
INTERNAL_API_TOKEN=3d8f1e9c2b7a4d6f0e3c5b8a9d1f4e7c2b0d5f8e3c6a9b1d4f7e0c2b5a8d1f4e
USER_SERVICE_URL=https://user-service-1095720168864-1095720168864.us-central1.run.app
NOTIFICATION_SERVICE_URL=https://notification-service-1095720168864-1095720168864.us-central1.run.app
GAMIFICATION_SERVICE_URL=https://gamification-service-1095720168864-1095720168864.us-central1.run.app
