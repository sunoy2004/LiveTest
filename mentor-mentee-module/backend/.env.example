# Async PostgreSQL URL for SQLAlchemy + asyncpg.
# Database name must be `mentoring` (production Cloud SQL / pgAdmin "mentoring").
#
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/mentoring
# Cloud Run + Cloud SQL unix socket (example):
#   postgresql+asyncpg://USER:PASSWORD@/mentoring?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mentoring
