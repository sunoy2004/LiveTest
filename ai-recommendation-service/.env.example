REDIS_URL=redis://localhost:6379/0
# Same database as the mentoring service (`mentoring`). AI stores `match_profiles` / `match_interactions` here
# (Alembic uses table `alembic_version_ai_recommendation` so it does not clash with mentoring migrations).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mentoring
USER_SERVICE_URL=http://localhost:8000
INTERNAL_API_TOKEN=change-me-in-production
JWT_SECRET=secret
# Dev only: skip JWT verification on recommendations (not for production)
AI_TRUST_GATEWAY_HEADERS=false

# opensource (default) | vertex
EMBEDDING_PROVIDER=opensource
USE_VERTEX=false
# RECOMMENDATION_ENGINE=pgvector
# RECOMMENDATION_CACHE_TTL=300
# HYBRID_SCORING=false
